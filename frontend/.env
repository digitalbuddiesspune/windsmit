# Backend API URL
# For local development
VITE_BACKEND_URL=http://localhost:5001

# Frontend API URL (used by components)
# For local development — must match backend PORT (see backend/.env)
VITE_API_URL=http://localhost:5001/api

# For production, update these to your Render backend URL:
# VITE_BACKEND_URL=https://windsmit-backend.onrender.com
# VITE_API_URL=https://windsmit-backend.onrender.com/api
